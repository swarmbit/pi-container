# ---------- Stage 1: builder ----------
FROM node:22-bookworm-slim AS builder

ARG PI_VERSION={{piVersion}}

WORKDIR /build

# Install pi globally
RUN npm install -g --ignore-scripts @earendil-works/pi-coding-agent@${PI_VERSION}

# Install team package dependencies
COPY package/package.json /build/package/
RUN cd /build/package && npm install --omit=dev

# ---------- Stage 2: runtime ----------
FROM node:22-bookworm-slim AS runtime

ARG PI_VERSION={{piVersion}}
ENV PI_VERSION=${PI_VERSION}
ENV EDITOR=nvim
ENV VISUAL=nvim

# Install runtime dependencies (Docker CLI from official repo so the CLI is always
# available; mount the docker socket via the mounts config if needed)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gosu \
    gnupg \
    neovim \
    && rm -rf /var/lib/apt/lists/* \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    docker-ce-cli \
    docker-buildx-plugin \
    docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash pi-user

# Copy pi from builder
COPY --from=builder /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN rm -f /usr/local/bin/pi \
    && ln -s ../lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js /usr/local/bin/pi

# Copy team package (source from build context, deps from builder)
COPY package/ /opt/pi-package/
COPY --from=builder /build/package/node_modules /opt/pi-package/node_modules

# Copy entrypoint
COPY entrypoint.sh /opt/pi/entrypoint.sh
RUN chmod +x /opt/pi/entrypoint.sh

# Copy default settings
COPY settings/default-settings.json /opt/pi/default-settings.json

# Project workspace
WORKDIR /workspace

# Entrypoint runs as root to fix permissions, then drops to pi-user
ENTRYPOINT ["/opt/pi/entrypoint.sh"]
